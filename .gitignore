# --- Dependencies ---
node_modules/
**/node_modules/
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.py[cod]

# --- Builds / caches ---
.next/
**/.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo
.pytest_cache/
**/.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Env files (keep *.env.example) ---
.env
.env.*
!.env.example
!**/.env.example

# --- Model weights & runtime data (never commit; multi-GB) ---
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
**/.cache/
backend/models/
backend/uploads/
backend/outputs/

# --- Sample videos: commit ONLY the curated corpus under assets/samples/ ---
*.mp4
*.mov
*.webm
!assets/samples/
!assets/samples/*.mp4
!assets/samples/*.mov
!assets/samples/*.webm
# the committed e2e upload fixture (W2.T5 / T-402) — un-ignore the dir before the file
!frontend/e2e/fixtures/
!frontend/e2e/fixtures/*.mp4

# --- OS / editor ---
.DS_Store
*.log

# --- Internal / personal build docs (kept local; not for the public repo) ---
# Already-committed ones stay in git HISTORY until it is rewritten
# (git filter-repo) or the project is re-published as a fresh repo.
CLAUDE.md
**/CLAUDE.md
AGENTS.md
**/AGENTS.md
EXECUTE.md
SPEC_BUILD_HANDOVER.md
MAYAVIUS_UX_PRODUCTION_ANALYSIS.md

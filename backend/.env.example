# mayavius backend configuration. Copy to .env and adjust.
# All vars are MAYAVIUS_-prefixed (see app/config.py / spec/08 §6).
# Values below are the DEFAULTS — uncomment + change only what you need.

# Allowed frontend origins. Parsed as JSON by pydantic-settings — quote as a
# JSON array. Set to the deployed frontend origin for a real deploy (spec/11 §2.5).
# MAYAVIUS_CORS_ORIGINS=["http://localhost:3000"]

# Short-clip frame cap; clamped to min(.,64) at request build. Long video is the
# #1 scope risk — keep this tight on a public host (handover §4.6, spec/11 §2.5).
MAYAVIUS_MAX_CLIP_FRAMES=24

# Upload size guard (MB).
MAYAVIUS_MAX_UPLOAD_MB=64

# Active adapter id (spec/06 §4.6). Default = the VGGT + CoTracker3 combo.
# "fake" selects the no-ML FixtureAdapter (fixture mode for tests / e2e).
MAYAVIUS_ADAPTER=vggt+cotracker3

# Inference device: mps (Apple Silicon default) | cpu (fallback, slower) | cuda (cloud Space).
MAYAVIUS_DEVICE=mps

# Subsample target + MV4D playback fps (spec/06 §5 step 1; MV4D header).
MAYAVIUS_TARGET_FPS=12.0

# Static/dynamic split percentile threshold (spec/06 §5 step 5).
MAYAVIUS_MOTION_THRESH=0.95

# Static-point confidence cull floor (spec/06 §5 step 6).
MAYAVIUS_CONF_THRESH=0.5

# VGGT checkpoint id. Default is the NC research weights. Commercial static-only
# swap = facebook/VGGT-1B-Commercial (gated AUP; complete the HF access form first).
MAYAVIUS_VGGT_WEIGHTS=facebook/VGGT-1B

# Result-blob store. Resolved ABSOLUTE against the backend package root at startup
# (-> backend/outputs); served immutable by /jobs/{id}/result. Gitignored.
MAYAVIUS_RESULT_DIR=outputs

# mayavius backend configuration. Copy to .env and adjust. All vars MAYAVIUS_-prefixed.

# CORS origins are parsed as JSON by pydantic-settings — quote as a JSON array:
# MAYAVIUS_CORS_ORIGINS=["http://localhost:3000"]

# Short-clip cap (frames). Long video is the #1 scope risk (handover §7).
MAYAVIUS_MAX_CLIP_FRAMES=24

# Upload size guard (MB).
MAYAVIUS_MAX_UPLOAD_MB=64

# mayavius frontend env. Copy to .env.local (Next.js loads it automatically).
# NEXT_PUBLIC_* values are exposed to the browser (see src/config.ts / spec/08 §6).

# Backend / reconstruction API base URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Deployed frontend origin — drives metadataBase, canonical + OG/Twitter image
# URLs, sitemap.ts, and robots.ts. A REAL DEPLOY MUST SET THIS, else share cards
# and the sitemap point at localhost and the share surface breaks (spec/11 §3).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
